generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id             String          @id @default(cuid())
  name           String?
  email          String?         @unique
  phone          String?         @unique
  image          String?
  emailVerified  DateTime?
  role           Role            @default(PARENT)
  createdAt      DateTime        @default(now())
  classId        String?
  accounts       Account[]
  sentMessages   Message[]
  parentStudents ParentStudent[]
  sessions       Session[]
  class          Class?          @relation(fields: [classId], references: [id])
}

model Class {
  id       String    @id @default(cuid())
  name     String
  students Student[]
  teachers User[]
}

model Student {
  id       String          @id @default(cuid())
  name     String
  classId  String
  messages Message[]
  parents  ParentStudent[]
  class    Class           @relation(fields: [classId], references: [id])
  records  StudentRecord[]
}

model ParentStudent {
  userId    String
  studentId String
  student   Student @relation(fields: [studentId], references: [id])
  user      User    @relation(fields: [userId], references: [id])

  @@id([userId, studentId])
}

model Message {
  id                String        @id @default(cuid())
  createdAt         DateTime      @default(now())
  content           String
  senderId          String
  studentId         String
  status            MessageStatus @default(PENDING)
  botResponse       String?
  botAnsweredAt     DateTime?
  dataAsOf          DateTime?
  teacherResponse   String?
  teacherAnsweredAt DateTime?
  skipReason        String?
  flaggedByParent   Boolean       @default(false)
  sender            User          @relation(fields: [senderId], references: [id])
  student           Student       @relation(fields: [studentId], references: [id])
}

model StudentRecord {
  id         String     @id @default(cuid())
  studentId  String
  date       DateTime
  recordType RecordType
  details    String
  importId   String
  import     DataImport @relation(fields: [importId], references: [id])
  student    Student    @relation(fields: [studentId], references: [id])
}

model DataImport {
  id          String          @id @default(cuid())
  importedAt  DateTime        @default(now())
  filename    String
  recordCount Int
  records     StudentRecord[]
}

enum Role {
  TEACHER
  PARENT
  ADMIN
}

enum MessageStatus {
  PENDING
  BOT_ANSWERED
  TEACHER_ANSWERED
  FORWARDED
}

enum RecordType {
  ATTENDANCE
  GRADE
  SCHEDULE
  OTHER
}
