generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id                  String             @id @default(cuid())
  name                String?
  email               String?            @unique
  phone               String?
  image               String?
  emailVerified       DateTime?
  role                Role               @default(PARENT)
  accessStatus        AccessStatus       @default(PENDING)
  requestedChildName  String?
  parentType          String?            // "אבא" or "אמא"
  createdAt           DateTime           @default(now())
  classId             String?
  studentId           String?            @unique  // for STUDENT role — links to Student record
  accounts            Account[]
  sentMessages        Message[]
  parentStudents      ParentStudent[]
  sessions            Session[]
  teacherRecords      TeacherRecord[]
  pushSubscriptions   PushSubscription[]
  class               Class?             @relation(fields: [classId], references: [id])
  studentRecord       Student?           @relation(fields: [studentId], references: [id])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @db.Text
  p256dh    String   @db.Text
  auth      String   @db.Text
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, endpoint])
  @@index([userId])
}

enum AccessStatus {
  PENDING
  APPROVED
  DENIED
}

enum Role {
  TEACHER
  PARENT
  STUDENT
  ADMIN
}

model FeatureInterest {
  id        String   @id @default(cuid())
  userId    String
  feature   String
  createdAt DateTime @default(now())

  @@unique([userId, feature])
}

model Class {
  id                   String    @id @default(cuid())
  name                 String
  displayName          String    @default("")   // e.g. "י2 סילבר"
  teacherDisplayName   String    @default("")   // e.g. "אליאב גיל"
  schoolName           String    @default("")   // e.g. "כפר סילבר"
  students             Student[]
  teachers             User[]
}

model Student {
  id              String                 @id @default(cuid())
  name            String
  idNumber        String?                @unique // ת.ז
  classId         String
  messages        Message[]
  parents         ParentStudent[]
  class           Class                  @relation(fields: [classId], references: [id])
  records         StudentRecord[]
  grades          StudentGrade[]
  attendance      StudentAttendance?
  userAccount     User?
  accommodations  StudentAccommodation[]
  emotionalNotes  EmotionalNote[]
}

model ParentStudent {
  userId    String
  studentId String
  student   Student @relation(fields: [studentId], references: [id])
  user      User    @relation(fields: [userId], references: [id])

  @@id([userId, studentId])
}

model Message {
  id                String        @id @default(cuid())
  createdAt         DateTime      @default(now())
  content           String        @db.Text
  senderId          String
  studentId         String
  status            MessageStatus @default(PENDING)
  botResponse       String?       @db.Text
  botAnsweredAt     DateTime?
  dataAsOf          DateTime?
  teacherResponse   String?       @db.Text
  teacherAnsweredAt DateTime?
  skipReason        String?
  flaggedByParent   Boolean       @default(false)
  teacherApproved   Boolean       @default(false)
  teacherSeenAt     DateTime?
  isTask            Boolean       @default(false)
  sender            User          @relation(fields: [senderId], references: [id])
  student           Student       @relation(fields: [studentId], references: [id])

  @@index([teacherSeenAt, createdAt])
  @@index([studentId])
}

enum MessageStatus {
  PENDING
  BOT_ANSWERED
  TEACHER_ANSWERED
  FORWARDED
}

// Legacy import system (kept for compatibility)
model StudentRecord {
  id         String     @id @default(cuid())
  studentId  String
  date       DateTime
  recordType RecordType
  details    String     @db.Text
  importId   String
  import     DataImport @relation(fields: [importId], references: [id])
  student    Student    @relation(fields: [studentId], references: [id])
}

enum RecordType {
  ATTENDANCE
  GRADE
  SCHEDULE
  OTHER
}

model DataImport {
  id          String          @id @default(cuid())
  importedAt  DateTime        @default(now())
  filename    String
  recordCount Int
  records     StudentRecord[]
}

// ── New tables ──────────────────────────────────────────

// Teacher directory (אלפון מורים)
model Teacher {
  id       String  @id @default(cuid())
  name     String
  phone    String?
  mobile   String?
  email    String?
  city     String?
  subjects String? // comma-separated
  role     String?
}

// Per-student per-subject grades with weighted average (ציונים שוטפים)
model StudentGrade {
  id              String   @id @default(cuid())
  studentId       String
  student         Student  @relation(fields: [studentId], references: [id])
  subject         String   // e.g. "אזרחות"
  teacherName     String?
  gradeComponents Json     // array of {name, weight, score}
  weightedAverage Float?
  updatedAt       DateTime @default(now())

  @@unique([studentId, subject])
}

// Attendance counters (מונה התנהגות)
model StudentAttendance {
  id                     String   @id @default(cuid())
  studentId              String   @unique
  student                Student  @relation(fields: [studentId], references: [id])
  totalLessons           Int      @default(0)
  absences               Int      @default(0)
  justifiedAbsences      Int      @default(0)
  tardiness              Int      @default(0)
  justifiedTardiness     Int      @default(0)
  disruptions            Int      @default(0)
  updatedAt              DateTime @default(now())
}

// Class schedule (מערכת כיתתית)
model ScheduleSlot {
  id        String @id @default(cuid())
  classId   String
  dayHeb    String // ראשון, שני, ...
  period    String // "1, 08:45 - 09:30"
  content   String @db.Text // raw cell content (subject + teacher + room, may include splits)

  @@index([classId, dayHeb])
}

// Calendar events — exams, trips, events (לוח מבחנים + לוח פעילויות)
model CalendarEvent {
  id           String   @id @default(cuid())
  date         DateTime
  description  String   @db.Text
  type         String?
  note         String?
  forAll       Boolean  @default(false)
  forTeacher   Boolean  @default(false)
  forGradeTeam Boolean  @default(false)
  forStudents  Boolean  @default(false)
  forParents   Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([date])
}

// Teacher notes — voice-dictated or manual records per student
model TeacherRecord {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  teacherId   String
  classId     String
  classLabel  String
  studentName String
  category    String   // חיסור | איחור | הפרעה | אירוע חיובי | אחר
  note        String?  @db.Text
  source      String   @default("הכתבה קולית") // "הכתבה קולית" | "ידני"
  teacher     User     @relation(fields: [teacherId], references: [id])

  @@index([teacherId, createdAt])
  @@index([classId])
}

// Bot response cache — avoid repeat Claude calls for identical questions
model BotCache {
  id        String   @id @default(cuid())
  userId    String
  question  String   @db.Text
  answer    String   @db.Text
  fromBot   String   @default("student") // "student" | "parent"
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

// ── Teacher-entered tasks (not from chat) ─────────────────
model TeacherTask {
  id          String    @id @default(cuid())
  classId     String
  description String    @db.Text
  responsible String?
  deadline    DateTime?
  note        String?   @db.Text
  done        Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([classId, done])
}

// ── Student personal accommodations ──────────────────────
model StudentAccommodation {
  id          String   @id @default(cuid())
  studentId   String
  classId     String
  type        String   // "private_lesson" | "therapy" | "special_activity" | "other"
  description String   @db.Text
  provider    String?
  subject     String?
  dayHeb      String?
  timeSlot    String?
  note        String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  student     Student  @relation(fields: [studentId], references: [id])

  @@index([classId])
  @@index([studentId])
}

// ── Emotional-social tracking ─────────────────────────────
model EmotionalNote {
  id        String   @id @default(cuid())
  studentId String
  classId   String
  type      String   @default("teacher") // "teacher" | "parent" | "survey"
  content   String   @db.Text
  score     Int?     // 1–5 wellbeing score
  date      DateTime @default(now())
  createdAt DateTime @default(now())
  student   Student  @relation(fields: [studentId], references: [id])

  @@index([classId, date])
  @@index([studentId])
}
